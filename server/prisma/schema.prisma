generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Uploads {
  id String @id @default(cuid())

  originalName String
  filename     String
  path         String
  mimetype     String
  size         Int

  user String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("uploads")
}

model Chat {
  id     String @id @default(cuid())
  userId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("chats")
}
